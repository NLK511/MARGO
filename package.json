{
  "name": "margo",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "e2e": "vitest run tests/e2e --passWithNoTests",
    "e2e:visual": "vitest run tests/visual --passWithNoTests",
    "e2e:update-snapshots": "vitest run tests/visual --passWithNoTests --update",
    "a11y": "vitest run tests/accessibility --passWithNoTests",
    "format:check": "prettier --check .",
    "start": "bash scripts/start.sh",
    "stop": "bash scripts/stop.sh",
    "deploy": "bash scripts/deploy.sh",
    "backup": "bash scripts/backup.sh",
    "restore": "bash scripts/restore.sh",
    "db:migrate": "pnpm --filter @margo/db db:migrate",
    "db:seed": "pnpm --filter @margo/db db:seed",
    "theme:migrate": "pnpm --filter @margo/db theme:migrate",
    "bundle:public": "node scripts/check-public-bundle.mjs",
    "docs:check": "vitest run tests/hardening/m9-hardening.test.ts --passWithNoTests"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^22.10.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "eslint": "^9.39.1",
    "eslint-config-next": "^15.5.6",
    "prettier": "^3.6.2",
    "turbo": "^2.6.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.3",
    "vitest": "^3.2.4"
  }
}
