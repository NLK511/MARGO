{
  "name": "@margo/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.json",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "db:generate": "DATABASE_URL=${DATABASE_URL:-postgresql://margo:margo@localhost:5432/margo?schema=public} prisma generate",
    "db:migrate": "DATABASE_URL=${DATABASE_URL:-postgresql://margo:margo@localhost:5432/margo?schema=public} prisma migrate dev",
    "db:deploy": "DATABASE_URL=${DATABASE_URL:-postgresql://margo:margo@localhost:5432/margo?schema=public} prisma migrate deploy",
    "db:seed": "DATABASE_URL=${DATABASE_URL:-postgresql://margo:margo@localhost:5432/margo?schema=public} tsx prisma/seed.ts",
    "db:validate": "DATABASE_URL=${DATABASE_URL:-postgresql://margo:margo@localhost:5432/margo?schema=public} prisma validate",
    "theme:migrate": "DATABASE_URL=${DATABASE_URL:-postgresql://margo:margo@localhost:5432/margo?schema=public} tsx src/theme-migration.ts"
  },
  "devDependencies": {
    "prisma": "^6.19.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0"
  }
}
