{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@margo/core": ["packages/core/src/index.ts"],
      "@margo/ui": ["packages/ui/src/index.tsx"],
      "@margo/design": ["packages/design/src/index.ts"],
      "@margo/themes": ["packages/themes/src/index.ts"],
      "@margo/modules": ["packages/modules/src/index.ts"],
      "@margo/db": ["packages/db/src/index.ts"],
      "@margo/validators": ["packages/validators/src/index.ts"],
      "@margo/types": ["packages/types/src/index.ts"]
    }
  }
}
